      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"token": "string"}
    },
    {
      "name": "Login user",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "username": "testuser123", "password": "pass123"},
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"token": "string"}
